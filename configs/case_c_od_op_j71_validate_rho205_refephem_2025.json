{
  "inputs": {
    "navsol_day1_csv": "data/navsol_2024-05-01_all.csv",
    "navsol_day2_csv": "data/navsol_2024-05-02_all.csv",
    "reference_ephem_csv": "outputs_day2_ref/op_ephemeris.csv"
  },

  "validate": {
  "compare_target": "reference_ephemeris"
  },
  
  "arc_gap_s": 1.5,

  "od": {
    "arc_mode": "all",
    "anchor": "last",
    "downsample_s": 10,
    "pos_sigma_m": 30.0
  },

  "op": {
    "time_start_utc": "2024-05-01T10:33:32Z",
    "span_hours": 38,
    "step_s": 30
  },

  "reference_frame": "TOD",

  "forces": {
    "profile": "microcosm_like",
    "mass_kg": 25.7,
    "area_m2": 0.1200,
    "cd0": 2.2,
    "estimate_cd": false,
    "cd_min": 1.0,
    "cd_max": 4.0,

    "use_srp": true,
    "cr0": 1.5,
    "estimate_cr": false,
    "cr_min": 0.5,
    "cr_max": 3.0,

    "gravity_degree": 70,
    "gravity_order": 70,
    "use_third_body": true,

    "drag_enabled": true,
    "atmosphere": "JACCHIA71",

    "j71_f107_avg": 150.0,
    "j71_f107_daily": 150.0,
    "j71_kp_3h": 2.0,
    "j71_base_density_mode": "TABLE87_3",
    "j71_density_scale": 2.05,
    "j71_use_diurnal_variation": false,
    "j71_enable_diagnostics": false,
    "j71_debug_log_path": "outputs_j71_rho205_refcmp/j71_diag.csv",
    "j71_debug_every_n": 200,
    "j71_debug_max_records": 2000,
    "j71_driver_mode": "CSV",
    "j71_space_weather_csv": "data/j71_space_weather_20240501_0503.csv",
    "j71_driver_max_age_days": 2.0,

    "rho0": 3.614e-13,
    "h0_m": 500000.0,
    "h_scale_m": 60000.0,

    "use_tides": true,
    "tide_system": "ZERO_TIDE"
  },

  "outputs_dir": "outputs_j71_rho205_refcmp",

  "orekit_extra_data_paths": [
    "data/eop",
    "data/space-weather"
  ]
}